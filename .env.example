# ── Required for cloud deployment ────────────────────────────────────────
# Get from: Supabase → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Get from: https://console.groq.com → API Keys (free)
GROQ_API_KEY=gsk_...

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# ── Optional: Google OAuth (enables "Continue with Google" button) ────────
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Application type: Web application)
# 3. Add Authorized redirect URIs:
#      https://forever-ai.onrender.com/auth/google/callback
#      http://127.0.0.1:5050/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Optional: alternative LLM providers ──────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
